{
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "importHelpers": false,
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "noEmitHelpers": true,
    "noUnusedLocals": true,
    "noEmit": true,
    "noUnusedParameters": true,
    "removeComments": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "target": "ESNext",
    "inlineSourceMap": true,
    "esModuleInterop": true,
    "stripInternal": true,
    "importsNotUsedAsValues": "remove",
    "lib": ["ES2020", "esnext"],
    "types": ["@types/node"]
  },
  "exclude": ["node_modules"]
}
