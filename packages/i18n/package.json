{
  "name": "@amniel/i18n",
  "version": "0.1.0",
  "main": "lib/index.js",
  "browser": "lib/browser.js",
  "types": "lib/index.d.ts",
  "license": "Apache-2.0",
  "author": "Amniel",
  "exports": {
    ".": "./lib/index.js",
    "./esm": "./lib/esm.mjs"
  },
  "files": [
    "./lib/index.js",
    "./lib/esm.mjs",
    "./lib/index.d.ts",
    "./lib/bindings.js"
  ],
  "scripts": {
    "artifacts": "napi artifacts -d ../../artifacts",
    "build": "napi build --platform --js bindings.js --release -o lib",
    "build:debug": "napi build --platform --js bindings.js -o lib",
    "prepublishOnly": "napi prepublish",
    "version": "napi version"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/TheAmniel/node-rs.git"
  },
  "napi": {
    "binaryName": "i18n",
    "targets": [
      "x86_64-pc-windows-msvc",
      "x86_64-unknown-linux-gnu",
      "x86_64-unknown-linux-musl",
      "x86_64-unknown-freebsd",
      "wasm32-wasip1-threads"
    ]
  },
  "engines": {
    "node": ">= 12"
  },
  "devDependencies": {
    "@napi-rs/cli": "catalog:"
  }
}
